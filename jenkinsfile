pipeline {
    agent any

    stages {
        stage ('Retrieve Code'){
            steps{
                git branch: "main" , url: "https://github.com/TomasBruen/TomsPetitions.git"
            }
        }

        stage ('build') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage ('test') {
            steps {
                sh 'mvn test'
            }
        }

        stage ('Package') {
            steps {
                sh 'mvn -DskipTests package'
            }
        }

        stage ('Deploy') {
            steps {
                sh 'sudo systemctl stop tomcat'
                sh 'rm -rf /opt/tomcat/webapps/*.war'
                sh 'cp target/app.war /opt/tomcat/webapps/'
                sh 'sudo systemctl start tomcat'
            }
        }
    }
}