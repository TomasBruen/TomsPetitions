pipeline {
    agent any

    stages {
        stage ('Setup') {
            steps {
                git 'https://github.com/TomasBruen/TomsPetitions.git'
            }     
        }

        stage ('build') {
            steps {
                sh 'mvn clean:clean'
                sh 'mvn dependency:copy-dependencies'
                sh 'mvn compiler:compile'
            }
        }

        stage ('test') {
            steps {
                sh 'mvn compiler:testCompile'
                sh 'mvn test'
            }
        }
    }
}